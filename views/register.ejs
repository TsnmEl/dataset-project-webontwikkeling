<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VALORANT — Register</title>
  <link href="https://fonts.googleapis.com/css2?family=DIN+Next+LT+Pro:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-body">
  <canvas id="bg-canvas"></canvas>

  <div class="login-container">
    <div class="login-logo">
      <img src="/assets/extra/ValorantLogo.png" alt="Valorant" class="login-logo-img">
      <div class="login-logo-text">VALORANT</div>
      <div class="login-logo-sub">Agent Intelligence System</div>
    </div>

    <div class="login-card">
      <div class="login-card-header">
        <div class="login-title">REGISTER</div>
        <div class="login-corner"></div>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form class="login-form" method="POST" action="/register">
        <div class="login-field">
          <label class="login-label">Username</label>
          <input class="login-input" type="text" name="username" placeholder="Choose a username" autocomplete="off" required>
        </div>
        <div class="login-field">
          <label class="login-label">Password</label>
          <input class="login-input" type="password" name="password" placeholder="Choose a password" required>
        </div>
        <button class="login-btn" type="submit">REGISTER</button>
      </form>

      <div class="login-footer">
        Already have an account? <a href="/login" class="login-link">Login here</a>
      </div>
    </div>
  </div>

  <script src="/js/canvas.js"></script>
</body>
</html>
