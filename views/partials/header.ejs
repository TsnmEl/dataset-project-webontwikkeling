<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VALORANT AGENT DATABASE</title>
<link href="https://fonts.googleapis.com/css2?family=DIN+Next+LT+Pro:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <canvas id="bg-canvas"></canvas>
    <nav class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-text">
                <span><img src="/assets/extra/ValorantLogo.png" alt="valorant-logo" class="valorant-logo"></span>
                VALORANT
            </div>
            <div class="logo-sub">Agent Intelligence System</div>
        </div>

        <a href="/home" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
                <path d="M9 21V12h6v9"/>
            </svg>
            Home
        </a>

        <a href="/agents" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'agents' ? 'active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="4" width="16" height="16" rx="2"/>
            <path d="M8 8h8"/><path d="M8 12h8"/><path d="M8 16h5"/>
            </svg>
            Agents
        </a>

        <a href="/roles" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'roles' ? 'active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="9"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="12" cy="12" r="1" fill="currentColor"/>
            </svg>
            Roles
        </a>

        <a href="/users" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'users' ? 'active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            Users
        </a>

        <div class="nav-logout">
          <% if (typeof currentUser !== 'undefined' && currentUser) { %>
            <div class="nav-user-info">
              Logged in as <span class="nav-user-name"><%= currentUser.username %></span><span class="nav-user-role"> · <%= currentUser.role %></span>
            </div>
          <% } %>
          <form method="POST" action="/logout">
            <button class="nav-item" type="submit">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
              Logout
            </button>
          </form>
        </div>
    </nav>

    <div id="loading" class="loading-overlay loading-hidden">
        <div class="loading-box">
            <img src="/assets/extra/Brimstone.gif" alt="Loading" class="loading-agent">
            <div class="loading-bar"></div>
            <div class="loading-text">CONNECTING...</div>
        </div>
    </div>
<main class="main">
    
